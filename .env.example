# ─────────────────────────────────────────────────────────────────────────────
# WD Portal API — Required Environment Variables
# Copy this file to .env (never commit .env to Git)
# On VPS: set these in systemd service file or Docker Compose environment block
# ─────────────────────────────────────────────────────────────────────────────

# Spring profile: local | staging | production
SPRING_PROFILES_ACTIVE=production

# ── Database ──────────────────────────────────────────────────────────────────
# Production example: jdbc:postgresql://your-db-host:5432/wd_production
# Local example:      jdbc:postgresql://localhost:5432/wd_local
DB_URL=jdbc:postgresql://localhost:5432/wd_local
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure 64-char hex string (NEVER reuse across environments):
#   openssl rand -hex 32
JWT_SECRET=generate_unique_64_char_hex_per_environment

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=info@walldotbuilders.com
MAIL_PASSWORD=Wall.builders2018

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
# Production: https://portal.walldotbuilders.com,https://walldotbuilders.com
# Local:      http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001

# ── File Storage ──────────────────────────────────────────────────────────────
# Local: absolute path to your local storage directory
# Production: /home/ftpuser/var/www/app/walldotbuilders/storage
# (Note: matches customer API storageBasePath exactly)
FILE_UPLOAD_DIR=/path/to/storage

# ── Swagger UI (disable in production, enable in local/staging) ───────────────
SWAGGER_ENABLED=false
