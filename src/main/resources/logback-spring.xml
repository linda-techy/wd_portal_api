<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ═══ Portal API log directory — separate from customer API ═══ -->
    <property name="LOG_DIR"       value="/home/backenduser/logs/portal-api"/>
    <property name="APP_NAME"      value="wd-portal-api"/>
    <property name="MAX_FILE_SIZE" value="50MB"/>
    <property name="MAX_HISTORY"   value="30"/>
    <property name="TOTAL_SIZE_CAP" value="2GB"/>

    <!-- CONSOLE — local profile only -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] %yellow(%logger{36}) [traceId=%X{traceId}] [userId=%X{userId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- application.log — plain text -->
    <appender name="APPLICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} [traceId=%X{traceId}] [userId=%X{userId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- error.log -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} ERROR [%thread] %logger{50} [traceId=%X{traceId}] [userId=%X{userId}] - %msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <!-- access.log -->
    <appender name="ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/access.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/access.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern></encoder>
    </appender>

    <!-- security.log -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/security.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/security.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern></encoder>
    </appender>

    <!-- performance.log -->
    <appender name="PERFORMANCE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/performance.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/performance.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern></encoder>
    </appender>

    <!-- application.log — JSON for production -->
    <appender name="APPLICATION_FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>userEmail</includeMdcKeyName>
            <includeMdcKeyName>httpMethod</includeMdcKeyName>
            <includeMdcKeyName>httpPath</includeMdcKeyName>
        </encoder>
    </appender>

    <appender name="ERROR_FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- Async wrappers -->
    <appender name="ASYNC_APP" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize><discardingThreshold>0</discardingThreshold>
        <appender-ref ref="APPLICATION_FILE"/>
    </appender>
    <appender name="ASYNC_APP_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize><discardingThreshold>0</discardingThreshold>
        <appender-ref ref="APPLICATION_FILE_JSON"/>
    </appender>
    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize><discardingThreshold>0</discardingThreshold><includeCallerData>true</includeCallerData>
        <appender-ref ref="ERROR_FILE"/>
    </appender>
    <appender name="ASYNC_ERROR_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize><discardingThreshold>0</discardingThreshold><includeCallerData>true</includeCallerData>
        <appender-ref ref="ERROR_FILE_JSON"/>
    </appender>

    <!-- Named loggers for dedicated log files -->
    <logger name="ACCESS_LOGGER"      level="INFO" additivity="false"><appender-ref ref="ACCESS_FILE"/></logger>
    <logger name="SECURITY_LOGGER"    level="INFO" additivity="false"><appender-ref ref="SECURITY_FILE"/></logger>
    <logger name="PERFORMANCE_LOGGER" level="INFO" additivity="false"><appender-ref ref="PERFORMANCE_FILE"/></logger>

    <logger name="org.hibernate.SQL"  level="WARN"/>
    <logger name="org.hibernate.type" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>

    <!-- LOCAL — console + DEBUG -->
    <springProfile name="local,default">
        <logger name="com.wd.api" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>
        <logger name="ACCESS_LOGGER"      level="DEBUG" additivity="false"><appender-ref ref="CONSOLE"/></logger>
        <logger name="SECURITY_LOGGER"    level="DEBUG" additivity="false"><appender-ref ref="CONSOLE"/></logger>
        <logger name="PERFORMANCE_LOGGER" level="DEBUG" additivity="false"><appender-ref ref="CONSOLE"/></logger>
        <root level="DEBUG"><appender-ref ref="CONSOLE"/></root>
    </springProfile>

    <!-- STAGING — plain text files + INFO -->
    <springProfile name="staging">
        <logger name="com.wd.api" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="ASYNC_APP"/>
            <appender-ref ref="ASYNC_ERROR"/>
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- PRODUCTION — JSON files, WARN focus, no debug -->
    <springProfile name="production">
        <logger name="com.wd.api" level="INFO"/>
        <logger name="org.springframework" level="WARN"/>
        <root level="INFO">
            <appender-ref ref="ASYNC_APP_JSON"/>
            <appender-ref ref="ASYNC_ERROR_JSON"/>
        </root>
    </springProfile>

</configuration>
