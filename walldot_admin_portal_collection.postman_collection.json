  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = {};",
                  "try {",
                  "    json = pm.response.json();",
                  "} catch (e) {}",
                  "",
                  "var accessToken = json.accessToken || json.token || json.jwt || '';",
                  "var refreshToken = json.refreshToken || '';",
                  "",
                  "if (accessToken) {",
                  "    pm.collectionVariables.set('accessToken', accessToken);",
                  "}",
                  "",
                  "if (refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@walldotbuilders.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticate and store access/refresh token in collection variables."
          }
        },
